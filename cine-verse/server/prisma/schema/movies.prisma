model Movie {
  id                String         @id @default(uuid())
  title             String         @unique
  synopsis          String         @db.Text
  thumbnail         String?
  genre             String[]
  language          String[]
  releaseYear       Int                         
  director          String                      
  cast              String[]                   
  streamingPlatform String[]                    
  
  type              ContentType    
  seasons           Int?
  episodes          Int?
  runtime           Int?
  
  streamingLink     String?
  
  pricing           PricingType    @default(FREE)  

  buyPrice          Float?         
  rentPrice         Float?        
  
  stripeBuyPriceId  String?
  stripeRentPriceId String?
  
  avgRating         Float          @default(0)
  reviewCount       Int            @default(0)
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  reviews           Review[]
  watchlists        Watchlist[]
  purchases         Purchase[]

  @@index([title])
  @@index([type])
  @@index([releaseYear])
  @@index([avgRating])
  @@map("movies")
}