<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Your OTP Code</title>
  </head>

  <body
    style="
      margin: 0;
      padding: 0;
      background: #f3f4f6;
      font-family: Arial, Helvetica, sans-serif;
    "
  >
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center" style="padding: 40px 0">
          <!-- Card Container -->
          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            style="
              max-width: 600px;
              background: #ffffff;
              border-radius: 12px;
              overflow: hidden;
              box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
            "
          >
            <!-- Header -->
            <tr>
              <td
                align="center"
                style="
                  background: linear-gradient(135deg, #4f46e5, #7c3aed);
                  padding: 30px;
                "
              >
                <h1 style="color: #ffffff; margin: 0; font-size: 22px">
                  OTP Verification
                </h1>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding: 35px; text-align: center">
                <h2 style="margin: 0; color: #111827">Hello <%= name %> 👋</h2>

                <p style="color: #6b7280; font-size: 15px; margin: 15px 0 25px">
                  Use the One-Time Password below to complete your verification.
                </p>

                <!-- OTP Box -->
                <div
                  style="
                    display: inline-block;
                    background: #111827;
                    color: #ffffff;
                    font-size: 28px;
                    font-weight: bold;
                    letter-spacing: 6px;
                    padding: 16px 35px;
                    border-radius: 8px;
                    margin-bottom: 20px;
                  "
                >
                  <%= otp %>
                </div>

                <!-- Expiry Notice -->
                <p
                  style="
                    color: #dc2626;
                    font-size: 14px;
                    font-weight: 600;
                    margin: 10px 0;
                  "
                >
                  ⏳ This OTP will expire in 2 minutes.
                </p>

                <p style="color: #9ca3af; font-size: 13px; margin-top: 25px">
                  Please do not share this code with anyone. If you did not
                  request this, you can safely ignore this email.
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td align="center" style="padding: 20px; background: #f9fafb">
                <p style="margin: 0; font-size: 12px; color: #9ca3af">
                  © 2026 Your App. All rights reserved.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
