<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Google Login</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Inter", sans-serif;
      }

      body {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #e0f7fa, #fffde7);
        color: #333;
      }

      .container {
        text-align: center;
        background: rgba(255, 255, 255, 0.8);
        padding: 40px 30px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        max-width: 400px;
      }

      h1 {
        font-size: 1.8rem;
        margin-bottom: 15px;
        color: #00796b;
      }

      p {
        font-size: 1rem;
        margin-bottom: 25px;
        line-height: 1.5;
      }

      .loader {
        border: 4px solid rgba(0, 0, 0, 0.1);
        border-top: 4px solid #00796b;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        margin: 0 auto 20px;
        animation: spin 1s linear infinite;
      }

      @keyframes spin {
        0% {
          transform: rotate(0deg);
        }
        100% {
          transform: rotate(360deg);
        }
      }

      .error {
        margin-top: 20px;
        background: rgba(255, 205, 210, 0.3);
        padding: 10px;
        border-radius: 10px;
        color: #b71c1c;
        font-size: 0.9rem;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Redirecting to Google...</h1>
      <div class="loader"></div>
      <p>Please wait while we securely redirect you to sign in.</p>
      <div id="errorMessage"></div>
    </div>

    <script>
      (async () => {
        try {
          const response = await fetch(
            "<%= betterAuthUrl %>/api/auth/sign-in/social",
            {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              credentials: "include",
              body: JSON.stringify({
                provider: "google",
                callbackURL: "<%= callbackURL %>",
              }),
            },
          );

          const data = await response.json();

          if (data.url) {
            window.location.href = data.url;
          } else {
            document.getElementById("errorMessage").innerHTML = `
              <div class="error">
                Error occurred while redirecting to Google. Please try again later.
              </div>`;
          }
        } catch (error) {
          document.getElementById("errorMessage").innerHTML = `
            <div class="error">
              Error occurred while redirecting to Google. Please try again later.
              <br>${error}
            </div>`;
        }
      })();
    </script>
  </body>
</html>
